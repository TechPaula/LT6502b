 10 REM x is the VIA address in decimal
 20 LET X = $BFC0
 29 REM Set port B AND a as output
 30 POKE X+2, 255
 31 POKE X+3, 255
 34 PRINT "DO A LITTLE JIG"
 35 FOR Z = 1 TO 5
 40 POKE X, 85
 41 POKE X+1, 85
 45 FOR T = 0 TO 100
 46 NEXT T
 50 POKE X, 170
 51 POKE X+1, 170
 55 FOR T = 0 TO 100
 56 NEXT T
 60 NEXT Z
 65 PRINT "COUNT UP ON PORT B, COUNT DOWN ON PORT A"
 70 FOR T = 0 TO 255
 80 POKE X, T
 85 POKE X+1, 255-T
 86 FOR DL = 0 TO 50
 87 NEXT DL
 90 NEXT T
 94 PRINT "NIGHT RIDER LIGHTS, CTRL+C TO STOP"
 95 Y = 1
 100 FOR Z = 1 TO 7
 110 POKE X, Y
 115 POKE X+1, Y
 120 Y = Y * 2
 125 FOR T = 1 TO 100
 126 NEXT T
 130 NEXT Z
 140 FOR Z = 1 TO 7
 150 POKE X, Y
 155 POKE X+1, Y
 160 Y = Y / 2
 165 FOR T = 1 TO 100
 166 NEXT T
 170 NEXT Z
 175 PRINT ".";
 180 GOTO 95
 