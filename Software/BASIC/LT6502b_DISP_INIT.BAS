10 REM -------------------------
11 REM DISPLAY parallel test
12 REM   For RA8889 based display



20 DT = $BFD1
21 RG = $BFD0


30 DA = 0        : REM DATA
31 TD = 0        : REM TEMP DATA



100 REM -- INIT RA8889, I HOPE --

110 GOSUB 9100    : REM CHECK STATUS
112 PRINT ".";
115 IF (TD AND %00000010)>0 THEN GOTO 110
117 PRINT " "

120 GOSUB 10400    : REM SOFTWARE RESET






















8999 END


9000 REM --- DUMP ALL REGISTERS
9005 PRINT "REG dump:"
9006 TD = 0
9010 FOR L1 = 0 TO 15
9012 PRINT HEX$(L1*16,2);
9013 PRINT "-";
9014 PRINT HEX$((L1*16)+15,2);
9015 PRINT ": ";
9020 FOR L2 = 0 TO 15
9030 POKE RG,TD         : REM SET REG TO READ
9040 DA = PEEK(DT)      : REM READ REGISTER
9050 PRINT HEX$(DA,2);  : REM PRINT REG VALUE
9060 PRINT " ";
9070 TD=TD+1
9080 NEXT L2
9090 PRINT ""
9095 NEXT L1
9096 TD = 0
9099 RETURN

9100 REM -- Read status
9110 TD = PEEK(RG)
9120 PRINT "STATUS:%";
9130 PRINT BIN$(TD)
9140 RETURN

10000 REM -- WRITE COMMAND/REG
10002 REM      COMMAND/REG IN TD
10010 POKE RG,TD
10099 RETURN


10100 REM -- WRITE DATA
10102 REM      DATA IN TD
10110 POKE DT,TD
10199 RETURN


10200 REM -- READ DATA
10202 REM      RESULT IN TD


10299 RETURN
10300 REM -- READ REGISTER
10302 REM      RESULT IN TD


10400 REM -- SOFTWARE RESET
10405 PRINT "SOFTWARE RESET"
10410 POKE RG,$00
10420 TD = PEEK(DT)
10430 PRINT BIN$(TD,8),
10440 TD = TD OR $01
10450 POKE DT,TD
10455 GOSUB 11000   : REM SHORT DELAY
10460 GOSUB 9100    : REM CHECK STATUS
10462 PRINT ".";
10465 IF (TD AND %00000010)>0 THEN GOTO 10460
10467 PRINT " "
10499 RETURN


11000 REM -- SHORT DELAY
11010 FOR T = 0 TO 100
11020 NEXT T
11030 RETURN

