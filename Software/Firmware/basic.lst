000000r 2               Cpntrh            = Cpntrl+1  ; continue pointer high byte
000000r 2               
000000r 2               Dlinel            = $8D       ; current DATA line low byte
000000r 2               Dlineh            = Dlinel+1  ; current DATA line high byte
000000r 2               
