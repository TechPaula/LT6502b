00E7A6  2  4E 45 58 54  ERR_NF      .byte "NEXT without FOR",$00
00E7AA  2  20 77 69 74  
00E7AE  2  68 6F 75 74  
00E7B7  2  53 79 6E 74  ERR_SN      .byte "Syntax",$00
00E7BB  2  61 78 00     
00E7BE  2  52 45 54 55  ERR_RG      .byte "RETURN without GOSUB",$00
00E7C2  2  52 4E 20 77  
00E7C6  2  69 74 68 6F  
00E7D3  2  4F 75 74 20  ERR_OD      .byte "Out of DATA",$00
00E7D7  2  6F 66 20 44  
00E7DB  2  41 54 41 00  
00E7DF  2  46 75 6E 63  ERR_FC      .byte "Function call",$00
00E7E3  2  74 69 6F 6E  
00E7E7  2  20 63 61 6C  
00E7ED  2  4F 76 65 72  ERR_OV      .byte "Overflow",$00
00E7F1  2  66 6C 6F 77  
00E7F5  2  00           
00E7F6  2  4F 75 74 20  ERR_OM      .byte "Out of memory",$00
00E7FA  2  6F 66 20 6D  
00E7FE  2  65 6D 6F 72  
00E804  2  55 6E 64 65  ERR_US      .byte "Undefined statement",$00
00E808  2  66 69 6E 65  
00E80C  2  64 20 73 74  
00E818  2  41 72 72 61  ERR_BS      .byte "Array bounds",$00
00E81C  2  79 20 62 6F  
00E820  2  75 6E 64 73  
00E825  2  44 6F 75 62  ERR_DD      .byte "Double dimension",$00
00E829  2  6C 65 20 64  
00E82D  2  69 6D 65 6E  
00E836  2  44 69 76 69  ERR_D0      .byte "Divide by zero",$00
00E83A  2  64 65 20 62  
00E83E  2  79 20 7A 65  
00E845  2  49 6C 6C 65  ERR_ID      .byte "Illegal direct",$00
00E849  2  67 61 6C 20  
00E84D  2  64 69 72 65  
00E854  2  54 79 70 65  ERR_TM      .byte "Type mismatch",$00
00E858  2  20 6D 69 73  
00E85C  2  6D 61 74 63  
00E862  2  53 74 72 69  ERR_LS      .byte "String too long",$00
00E866  2  6E 67 20 74  
00E86A  2  6F 6F 20 6C  
00E872  2  53 74 72 69  ERR_ST      .byte "String too complex",$00
00E876  2  6E 67 20 74  
00E87A  2  6F 6F 20 63  
00E885  2  43 61 6E 27  ERR_CN      .byte "Can't continue",$00
00E889  2  74 20 63 6F  
00E88D  2  6E 74 69 6E  
00E894  2  55 6E 64 65  ERR_UF      .byte "Undefined function",$00
00E898  2  66 69 6E 65  
00E89C  2  64 20 66 75  
00E8A7  2  4C 4F 4F 50  ERR_LD      .byte "LOOP without DO",$00
00E8AB  2  20 77 69 74  
00E8AF  2  68 6F 75 74  
00E8B7  2               
00E8B7  2               ;ERR_UV     .byte "Undefined variable",$00
00E8B7  2               
00E8B7  2               ; the above error has been tested and works (see code and comments below LAB_1D8B)
00E8B7  2               
00E8B7  2               ;ERR_UA     .byte "Undimensioned array",$00
00E8B7  2               
00E8B7  2  0D 0A 42 72  LAB_BMSG    .byte $0D,$0A,"Break",$00
00E8BB  2  65 61 6B 00  
00E8BF  2  20 45 72 72  LAB_EMSG    .byte " Error",$00
00E8C3  2  6F 72 00     
00E8C6  2  20 69 6E 20  LAB_LMSG    .byte " in line ",$00
00E8CA  2  6C 69 6E 65  
00E8CE  2  20 00        
00E8D0  2  0D 0A 52 65  LAB_RMSG    .byte $0D,$0A,"Ready",$0D,$0A,$00         ; TODO REMOVE EXCESS CRLF AS IT TAKES UP SPACE
00E8D4  2  61 64 79 0D  
00E8D8  2  0A 00        
00E8DA  2               
00E8DA  2  20 45 78 74  LAB_IMSG    .byte " Extra ignored",$0D,$0A,$00
00E8DE  2  72 61 20 69  
00E8E2  2  67 6E 6F 72  
00E8EB  2  20 52 65 64  LAB_REDO    .byte " Redo from start",$0D,$0A,$00
00E8EF  2  6F 20 66 72  
00E8F3  2  6F 6D 20 73  
00E8FE  2               
00E8FE  2               AA_end_basic
00E8FE  2               
00E8FE  1                   .include "ewoz.asm"
00E8FE  2               ; EWOZ Extended Woz Monitor.
00E8FE  2               ; Just a few mods to the original monitor.
00E8FE  2               
00E8FE  2               ; START @ $7000
00E8FE  2               
00E8FE  2               
00E8FE  2               
00E8FE  2               ;IO_AREA        = $A000
00E8FE  2               ;ACIA        = IO_AREA
00E8FE  2               ;ACIA_CTRL   = ACIA+3
00E8FE  2               ;ACIA_CMD    = ACIA+2
00E8FE  2               ;ACIA_SR     = ACIA+1
00E8FE  2               ;ACIA_DAT    = ACIA
00E8FE  2               
00E8FE  2               ;ACIAStatus  = IO_AREA		; FT245 Status
00E8FE  2               ;ACIAData    = IO_AREA+$01	; FT245 Data in/out
00E8FE  2                  .segment "WOZMON"
00E8FE  2                  .org    $F000
00F000  2               
00F000  2               IN          = $0300          ;*Input buffer
00F000  2               XAML        = $24            ;*Index pointers
00F000  2               XAMH        = $25
00F000  2               STL         = $26
00F000  2               STH         = $27
00F000  2               L           = $28
00F000  2               H           = $29
00F000  2               YSAV        = $2A
00F000  2               MODE        = $2B
00F000  2               MSGL        = $2C
00F000  2               MSGH        = $2D
00F000  2               COUNTER     = $2E
00F000  2               CRC         = $2F
00F000  2               CRCCHECK    = $30
00F000  2               
00F000  2               
00F000  2               EWOZ:
00F000  2  D8                 CLD             ;Clear decimal arithmetic mode.
00F001  2  58                 CLI
00F002  2               ;        LDA #$1F        ;* Init ACIA to 19200 Baud.
00F002  2               ;        STA ACIA_CTRL
00F002  2               ;        LDA #$0B        ;* No Parity.
00F002  2               ;        STA ACIA_CMD
00F002  2  A9 0D              LDA #$0D
00F004  2  20 20 F1           JSR ECHO      ;* New line.
00F007  2  A9 3C              LDA #<MSG1
00F009  2  85 2C              STA MSGL
00F00B  2  A9 F2              LDA #>MSG1
00F00D  2  85 2D              STA MSGH
00F00F  2  20 44 F1           JSR SHWMSG     ;* Show Welcome.
00F012  2  A9 0D              LDA #$0D
00F014  2  20 20 F1           JSR ECHO       ;* New line.
00F017  2               SOFTRESET:
00F017  2  A9 9B              LDA #$9B      ;* Auto escape.
00F019  2               NOTCR:
00F019  2  C9 88              CMP #$88      ;"<-"? * Note this was chaged to $88 which is the back space key.
00F01B  2  F0 13              BEQ BACKSPACE ;Yes.
00F01D  2  C9 9B              CMP #$9B      ;ESC?
00F01F  2  F0 03              BEQ ESCAPE    ;Yes.
00F021  2  C8                 INY           ;Advance text index.
00F022  2  10 19              BPL NEXTCHAR  ;Auto ESC if >127.
00F024  2               ESCAPE:
00F024  2  A9 DC              LDA #$DC      ;"\"
00F026  2  20 20 F1           JSR ECHO      ;Output it.
00F029  2               GETLINE:
00F029  2  A9 8D              LDA #$8D      ;CR.
00F02B  2  20 20 F1           JSR ECHO      ;Output it.
00F02E  2  A0 01              LDY #$01      ;Initiallize text index.
00F030  2               BACKSPACE:
00F030  2  88                 DEY           ;Backup text index.
00F031  2  30 F6              BMI GETLINE   ;Beyond start of line, reinitialize.
00F033  2  A9 A0              LDA #$A0      ;*Space, overwrite the backspaced char.
00F035  2  20 20 F1           JSR ECHO
00F038  2  A9 88              LDA #$88      ;*Backspace again to get to correct pos.
00F03A  2  20 20 F1           JSR ECHO
00F03D  2               NEXTCHAR:
00F03D  2  20 CA F3           JSR ACIAin           ; ? get character from console/keyboard
00F040  2               ;         LDA ACIAStatus      ;*See if we got an incoming char
00F040  2               ;         AND #$01            ;*Test bit 3
00F040  2               ;         CMP #$01
00F040  2               ;         BNE NEXTCHAR        ;*Wait for character
00F040  2               ;         LDA ACIAData        ;*Load char
00F040  2  90 FB              BCC NEXTCHAR         ; ?ACIAin function sets carry IF data is present, so if caary clear, wait for character
00F042  2  C9 60              CMP #$60             ;*Is it Lower case
00F044  2  30 02              BMI   CONVERT        ;*Nope, just convert it
00F046  2  29 5F              AND #$5F             ;*If lower case, convert to Upper case
00F048  2               CONVERT:
00F048  2  09 80              ORA #$80        ;*Convert it to "ASCII Keyboard" Input
00F04A  2  99 00 03           STA IN,Y        ;Add to text buffer.
00F04D  2  20 20 F1           JSR ECHO        ;Display character.
00F050  2  C9 8D              CMP #$8D        ;CR?
00F052  2  D0 C5              BNE NOTCR       ;No.
00F054  2  A0 FF              LDY #$FF        ;Reset text index.
00F056  2  A9 00              LDA #$00        ;For XAM mode.
00F058  2  AA                 TAX             ;0->X.
00F059  2               SETSTOR:
00F059  2  0A                 ASL             ;Leaves $7B if setting STOR mode.
00F05A  2               SETMODE:
00F05A  2  85 2B              STA MODE        ;$00 = XAM, $7B = STOR, $AE = BLOK XAM.
00F05C  2               BLSKIP:
00F05C  2  C8                 INY            ;Advance text index.
00F05D  2               NEXTITEM:
00F05D  2  B9 00 03           LDA IN,Y         ;Get character.
00F060  2  C9 8D              CMP #$8D        ;CR?
00F062  2  F0 C5              BEQ GETLINE     ;Yes, done this line.
00F064  2  C9 AE              CMP #$AE        ;"."?
00F066  2  90 F4              BCC BLSKIP      ;Skip delimiter.
00F068  2  F0 F0              BEQ SETMODE     ;Set BLOCK XAM mode.
00F06A  2  C9 BA              CMP #$BA        ;":"?
00F06C  2  F0 EB              BEQ SETSTOR     ;Yes, set STOR mode.
00F06E  2  C9 D2              CMP #$D2        ;"R"?
00F070  2  F0 36              BEQ RUN         ;Yes, run user program
00F072  2  C9 D1              CMP #$D1          ;? QUIT TO BASIC.
00F074  2  F0 31              BEQ EXIT          ;
00F076  2  C9 CC              CMP #$CC        ;* "L"?
00F078  2  F0 37              BEQ LOADINT     ;* Yes, Load Intel Code.
00F07A  2  86 28              STX L           ;$00->L.
00F07C  2  86 29              STX H           ; and H.
00F07E  2  84 2A              STY YSAV        ;Save Y for comparison.
00F080  2               NEXTHEX:
00F080  2  B9 00 03           LDA IN,Y        ;Get character for hex test.
00F083  2  49 B0              EOR #$B0        ;Map digits to $0-9.
00F085  2  C9 0A              CMP #$0A        ;Digit?
00F087  2  90 06              BCC DIG         ;Yes.
00F089  2  69 88              ADC #$88        ;Map letter "A"-"F" to $FA-FF.
00F08B  2  C9 FA              CMP #$FA        ;Hex letter?
00F08D  2  90 11              BCC NOTHEX      ;No, character not hex.
00F08F  2               DIG:
00F08F  2  0A                 ASL
00F090  2  0A                 ASL             ;Hex digit to MSD of A.
00F091  2  0A                 ASL
00F092  2  0A                 ASL
00F093  2  A2 04              LDX #$04        ;Shift count.
00F095  2               HEXSHIFT:
00F095  2  0A                 ASL             ;Hex digit left MSB to carry.
00F096  2  26 28              ROL L           ;Rotate into LSD.
00F098  2  26 29              ROL H           ;Rotate into MSD's.
00F09A  2  CA                 DEX             ;Done 4 shifts?
00F09B  2  D0 F8              BNE HEXSHIFT    ;No, loop.
00F09D  2  C8                 INY             ;Advance text index.
00F09E  2  D0 E0              BNE NEXTHEX     ;Always taken. Check next character for hex.
00F0A0  2               NOTHEX:
00F0A0  2  C4 2A              CPY YSAV        ;Check if L, H empty (no hex digits).
00F0A2  2  D0 13              BNE NOESCAPE   ;* Branch out of range, had to improvise...
00F0A4  2  4C 24 F0           JMP ESCAPE      ;Yes, generate ESC sequence.
00F0A7  2               EXIT:                         ; ? RTS TO BASIC
00F0A7  2  60                 RTS
00F0A8  2               
00F0A8  2               RUN:
00F0A8  2  20 AE F0           JSR ACTRUN      ;* JSR to the Address we want to run.
00F0AB  2  4C 17 F0           JMP SOFTRESET   ;* When returned for the program, reset EWOZ.
00F0AE  2               ACTRUN:
00F0AE  2  6C 24 00           JMP (XAML)      ;Run at current XAM index.
00F0B1  2               
00F0B1  2               LOADINT:
00F0B1  2  20 51 F1           JSR LOADINTEL   ;* Load the Intel code.
00F0B4  2  4C 17 F0           JMP SOFTRESET   ;* When returned from the program, reset EWOZ.
00F0B7  2               
00F0B7  2               NOESCAPE:
00F0B7  2  24 2B              BIT MODE        ;Test MODE byte.
00F0B9  2  50 0D              BVC NOTSTOR     ;B6=0 for STOR, 1 for XAM and BLOCK XAM
00F0BB  2  A5 28              LDA L           ;LSD's of hex data.
00F0BD  2  81 26              STA (STL, X)    ;Store at current "store index".
00F0BF  2  E6 26              INC STL         ;Increment store index.
00F0C1  2  D0 9A              BNE NEXTITEM    ;Get next item. (no carry).
00F0C3  2  E6 27              INC STH         ;Add carry to 'store index' high order.
00F0C5  2               TONEXTITEM:
00F0C5  2  4C 5D F0           JMP NEXTITEM    ;Get next command item.
00F0C8  2               NOTSTOR:
00F0C8  2  30 2B              BMI XAMNEXT     ;B7=0 for XAM, 1 for BLOCK XAM.
00F0CA  2  A2 02              LDX #$02        ;Byte count.
00F0CC  2               SETADR:
00F0CC  2  B5 27              LDA L-1,X       ;Copy hex data to
00F0CE  2  95 25              STA STL-1,X     ;"store index".
00F0D0  2  95 23              STA XAML-1,X    ;And to "XAM index'.
00F0D2  2  CA                 DEX             ;Next of 2 bytes.
00F0D3  2  D0 F7              BNE SETADR      ;Loop unless X = 0.
00F0D5  2               NXTPRNT:
00F0D5  2  D0 14              BNE PRDATA      ;NE means no address to print.
00F0D7  2  A9 8D              LDA #$8D        ;CR.
00F0D9  2  20 20 F1           JSR ECHO        ;Output it.
00F0DC  2  A5 25              LDA XAMH        ;'Examine index' high-order byte.
00F0DE  2  20 0D F1           JSR PRBYTE      ;Output it in hex format.
00F0E1  2  A5 24              LDA XAML        ;Low-order "examine index" byte.
00F0E3  2  20 0D F1           JSR PRBYTE      ;Output it in hex format.
00F0E6  2  A9 BA              LDA #$BA        ;":".
00F0E8  2  20 20 F1           JSR ECHO        ;Output it.
00F0EB  2               PRDATA:
00F0EB  2  A9 A0              LDA #$A0        ;Blank.
00F0ED  2  20 20 F1           JSR ECHO        ;Output it.
00F0F0  2  A1 24              LDA (XAML,X)    ;Get data byte at 'examine index".
00F0F2  2  20 0D F1           JSR PRBYTE      ;Output it in hex format.
00F0F5  2               XAMNEXT:
00F0F5  2  86 2B              STX MODE        ;0-> MODE (XAM mode).
00F0F7  2  A5 24              LDA XAML
00F0F9  2  C5 28              CMP L           ;Compare 'examine index" to hex data.
00F0FB  2  A5 25              LDA XAMH
00F0FD  2  E5 29              SBC H
00F0FF  2  B0 C4              BCS TONEXTITEM  ;Not less, so no more data to output.
00F101  2  E6 24              INC XAML
00F103  2  D0 02              BNE MOD8CHK     ;Increment 'examine index".
00F105  2  E6 25              INC XAMH
00F107  2               MOD8CHK:
00F107  2  A5 24              LDA XAML        ;Check low-order 'exainine index' byte
00F109  2  29 0F              AND #$0F        ;For MOD 8=0 ** changed to $0F to get 16 values per row **
00F10B  2  10 C8              BPL NXTPRNT     ;Always taken.
00F10D  2               PRBYTE:
00F10D  2  48                 PHA             ;Save A for LSD.
00F10E  2  4A                 LSR
00F10F  2  4A                 LSR
00F110  2  4A                 LSR             ;MSD to LSD position.
00F111  2  4A                 LSR
00F112  2  20 16 F1           JSR PRHEX       ;Output hex digit.
00F115  2  68                 PLA             ;Restore A.
00F116  2               PRHEX:
00F116  2  29 0F              AND #$0F        ;Mask LSD for hex print.
00F118  2  09 B0              ORA #$B0        ;Add "0".
00F11A  2  C9 BA              CMP #$BA        ;Digit?
00F11C  2  90 02              BCC ECHO        ;Yes, output it.
00F11E  2  69 06              ADC #$06        ;Add offset for letter.
00F120  2               ECHO:
00F120  2  48                 PHA             ;*Save A
00F121  2  29 7F              AND #$7F        ;*Change to "standard ASCII"
00F123  2               
00F123  2  48                 PHA
00F124  2  20 95 F5           JSR DISP_TEXT_WR
00F127  2  68                 PLA
00F128  2               
00F128  2  8D F1 BF           STA ACIAData      ;*Send it.
00F12B  2               
00F12B  2  C9 0D              CMP #$0D          ; is it a carriage return?
00F12D  2  D0 0A              BNE @WAIT
00F12F  2               
00F12F  2  48                 PHA               ; if it IS a CR then also send an LF!!!
00F130  2  A9 0A              LDA #$0A
00F132  2  8D F1 BF           STA ACIAData      ;*Send it.
00F135  2  20 95 F5           JSR DISP_TEXT_WR
00F138  2  68                 PLA
00F139  2               
00F139  2               @WAIT:
00F139  2  AD F0 BF           LDA ACIAStatus    ;*Load status register for ACIA
00F13C  2  29 02              AND #$02          ;*Mask bit 2.
00F13E  2  C9 02              CMP #$02
00F140  2  D0 F7              BNE @WAIT         ;*ACIA not done yet, wait.
00F142  2               
00F142  2  68                 PLA               ;*Restore A
00F143  2  60                 RTS               ;*Done, over and out...
00F144  2               
00F144  2               SHWMSG:
00F144  2  A0 00              LDY #$0
00F146  2               @PRINT:
00F146  2  B1 2C              LDA (MSGL),Y
00F148  2  F0 06              BEQ @DONE
00F14A  2  20 20 F1           JSR ECHO
00F14D  2  C8                 INY
00F14E  2  D0 F6              BNE @PRINT
00F150  2               @DONE:
00F150  2  60                 RTS
00F151  2               
00F151  2               ; Load an program in Intel Hex Format.
00F151  2               LOADINTEL:
00F151  2  A9 0D              LDA #$0D
00F153  2  20 20 F1           JSR ECHO          ;New line.
00F156  2  A9 51              LDA #<MSG2
00F158  2  85 2C              STA MSGL
00F15A  2  A9 F2              LDA #>MSG2
00F15C  2  85 2D              STA MSGH
00F15E  2  20 44 F1           JSR SHWMSG        ;Show Start Transfer.
00F161  2  A9 0D              LDA #$0D
00F163  2  20 20 F1           JSR ECHO          ;New line.
00F166  2  A0 00              LDY #$00
00F168  2  84 30              STY CRCCHECK      ;If CRCCHECK=0, all is good.
00F16A  2               INTELLINE:
00F16A  2  20 2F F2           JSR GETCHAR       ;Get char
00F16D  2  99 00 03           STA IN,Y          ;Store it
00F170  2  C8                 INY               ;Next
00F171  2  C9 1B              CMP #$1B          ;Escape ?
00F173  2  F0 67              BEQ INTELDONE     ;Yes, abort.
00F175  2  C9 0D              CMP #$0D          ;Did we find a new line ?
00F177  2  D0 F1              BNE INTELLINE     ;Nope, continue to scan line.
00F179  2  A0 FF              LDY #$FF          ;Find (:)
00F17B  2               FINDCOL:
00F17B  2  C8                 INY
00F17C  2  B9 00 03           LDA IN,Y
00F17F  2  C9 3A              CMP #$3A          ; Is it Colon ?
00F181  2  D0 F8              BNE FINDCOL       ; Nope, try next.
00F183  2  C8                 INY               ; Skip colon
00F184  2  A2 00              LDX #$00          ; Zero in X
00F186  2  86 2F              STX CRC           ; Zero Check sum
00F188  2  20 0C F2           JSR GETHEX        ; Get Number of bytes.
00F18B  2  85 2E              STA COUNTER       ; Number of bytes in Counter.
00F18D  2  18                 CLC               ; Clear carry
00F18E  2  65 2F              ADC CRC           ; Add CRC
00F190  2  85 2F              STA CRC           ; Store it
00F192  2  20 0C F2           JSR GETHEX        ; Get Hi byte
00F195  2  85 27              STA STH           ; Store it
00F197  2  18                 CLC               ; Clear carry
00F198  2  65 2F              ADC CRC           ; Add CRC
00F19A  2  85 2F              STA CRC           ; Store it
00F19C  2  20 0C F2           JSR GETHEX        ; Get Lo byte
00F19F  2  85 26              STA STL           ; Store it
00F1A1  2  18                 CLC               ; Clear carry
00F1A2  2  65 2F              ADC CRC           ; Add CRC
00F1A4  2  85 2F              STA CRC           ; Store it
00F1A6  2  A9 2E              LDA #$2E          ; Load "."
00F1A8  2  20 20 F1           JSR ECHO          ; Print it to indicate activity.
00F1AB  2               NODOT:
00F1AB  2  20 0C F2           JSR GETHEX        ; Get Control byte.
00F1AE  2  C9 01              CMP   #$01        ; Is it a Termination record ?
00F1B0  2  F0 2A              BEQ   INTELDONE   ; Yes, we are done.
00F1B2  2  18                 CLC               ; Clear carry
00F1B3  2  65 2F              ADC CRC           ; Add CRC
00F1B5  2  85 2F              STA CRC           ; Store it
00F1B7  2               INTELSTORE:
00F1B7  2  20 0C F2           JSR GETHEX        ; Get Data Byte
00F1BA  2  81 26              STA (STL,X)       ; Store it
00F1BC  2  18                 CLC               ; Clear carry
00F1BD  2  65 2F              ADC CRC           ; Add CRC
00F1BF  2  85 2F              STA CRC           ; Store it
00F1C1  2  E6 26              INC STL           ; Next Address
00F1C3  2  D0 02              BNE TESTCOUNT     ; Test to see if Hi byte needs INC
00F1C5  2  E6 27              INC STH           ; If so, INC it.
00F1C7  2               TESTCOUNT:
00F1C7  2  C6 2E              DEC COUNTER       ; Count down.
00F1C9  2  D0 EC              BNE INTELSTORE    ; Next byte
00F1CB  2  20 0C F2           JSR GETHEX        ; Get Checksum
00F1CE  2  A0 00              LDY #$00          ; Zero Y
00F1D0  2  18                 CLC               ; Clear carry
00F1D1  2  65 2F              ADC CRC           ; Add CRC
00F1D3  2  F0 95              BEQ INTELLINE     ; Checksum OK.
00F1D5  2  A9 01              LDA #$01          ; Flag CRC error.
00F1D7  2  85 30              STA   CRCCHECK    ; Store it
00F1D9  2  4C 6A F1           JMP INTELLINE     ; Process next line.
00F1DC  2               
00F1DC  2               INTELDONE:
00F1DC  2  A5 30              LDA CRCCHECK      ; Test if everything is OK.
00F1DE  2  F0 16              BEQ OKMESS        ; Show OK message.
00F1E0  2  A9 0D              LDA #$0D
00F1E2  2  20 20 F1           JSR ECHO          ; New line.
00F1E5  2  A9 87              LDA #<MSG4        ; Load Error Message
00F1E7  2  85 2C              STA MSGL
00F1E9  2  A9 F2              LDA #>MSG4
00F1EB  2  85 2D              STA MSGH
00F1ED  2  20 44 F1           JSR SHWMSG        ;Show Error.
00F1F0  2  A9 0D              LDA #$0D
00F1F2  2  20 20 F1           JSR ECHO          ;New line.
00F1F5  2  60                 RTS
00F1F6  2               
00F1F6  2               OKMESS:
00F1F6  2  A9 0D              LDA #$0D
00F1F8  2  20 20 F1           JSR ECHO          ;New line.
00F1FB  2  A9 70              LDA #<MSG3        ;Load OK Message.
00F1FD  2  85 2C              STA MSGL
00F1FF  2  A9 F2              LDA #>MSG3
00F201  2  85 2D              STA MSGH
00F203  2  20 44 F1           JSR SHWMSG        ;Show Done.
00F206  2  A9 0D              LDA #$0D
00F208  2  20 20 F1           JSR ECHO          ;New line.
00F20B  2  60                 RTS
00F20C  2               
00F20C  2               GETHEX:
00F20C  2  B9 00 03           LDA IN,Y          ;Get first char.
00F20F  2  49 30              EOR #$30
00F211  2  C9 0A              CMP #$0A
00F213  2  90 02              BCC DONEFIRST
00F215  2  69 08              ADC #$08
00F217  2               DONEFIRST:
00F217  2  0A                 ASL
00F218  2  0A                 ASL
00F219  2  0A                 ASL
00F21A  2  0A                 ASL
00F21B  2  85 28              STA L
00F21D  2  C8                 INY
00F21E  2  B9 00 03           LDA IN,Y          ;Get next char.
00F221  2  49 30              EOR #$30
00F223  2  C9 0A              CMP #$0A
00F225  2  90 02              BCC DONESECOND
00F227  2  69 08              ADC #$08
00F229  2               DONESECOND:
00F229  2  29 0F              AND #$0F
00F22B  2  05 28              ORA L
00F22D  2  C8                 INY
00F22E  2  60                 RTS
00F22F  2               
00F22F  2               GETCHAR:
00F22F  2  AD F0 BF           LDA ACIAStatus  ;See if we got an incoming char
00F232  2  29 01              AND #$01        ;Test bit 3
00F234  2  C9 01              CMP #$01
00F236  2  D0 F7              BNE GETCHAR     ;Wait for character
00F238  2  AD F1 BF           LDA ACIAData    ;Load char
00F23B  2  60                 RTS
00F23C  2               
00F23C  2               MSG1:
00F23C  2  57 65 6C 63        .byte "Welcome to EWOZ 1.0.",0
00F240  2  6F 6D 65 20  
00F244  2  74 6F 20 45  
00F251  2               MSG2:
00F251  2  53 74 61 72        .byte "Start Intel Hex code Transfer.",0
00F255  2  74 20 49 6E  
00F259  2  74 65 6C 20  
00F270  2               MSG3:
00F270  2  49 6E 74 65        .byte "Intel Hex Imported OK.",0
00F274  2  6C 20 48 65  
00F278  2  78 20 49 6D  
00F287  2               MSG4:
00F287  2  49 6E 74 65        .byte "Intel Hex Imported with checksum error.",0
00F28B  2  6C 20 48 65  
00F28F  2  78 20 49 6D  
00F2AF  2               
00F2AF  2               
00F2AF  2               
00F2AF  2               
00F2AF  2               
00F2AF  2               
00F2AF  1               ;	.include ""
00F2AF  1               
00F2AF  1               ; put the IRQ and MNI code in RAM so that it can be changed
00F2AF  1               
00F2AF  1               IRQ_vec	= VEC_SV+2		; IRQ code vector
00F2AF  1               NMI_vec	= IRQ_vec+$0A	; NMI code vector
00F2AF  1               
00F2AF  1               ; setup for the 6502 simulator environment
00F2AF  1               
00F2AF  1               IO_AREA	= $BFF0		; set I/O area for this monitor (Console port)
00F2AF  1               
00F2AF  1               
00F2AF  1               ;ACIAsimwr	= IO_AREA+$01	; simulated ACIA write port
00F2AF  1               ;ACIAsimrd	= IO_AREA+$04	; simulated ACIA read port
00F2AF  1               ACIAStatus	= IO_AREA		; FT245 Status
00F2AF  1               ACIAData	= IO_AREA+$01	; FT245 Data in/out
00F2AF  1               
00F2AF  1               ; Keyboard ACIA (65c51) memory locations
00F2AF  1               A_rxd           = $BFE0 ; ACIA receive data port
00F2AF  1               A_txd           = $BFE0 ; ACIA transmit data port
00F2AF  1               A_sts           = $BFE1 ; ACIA status port
00F2AF  1               A_res           = $BFE1 ; ACIA reset port
00F2AF  1               A_cmd           = $BFE2 ; ACIA command port
00F2AF  1               A_ctl           = $BFE3 ; ACIA control port
00F2AF  1               
00F2AF  1               ; Beeper bits
00F2AF  1               A_Beeper		= $BFA0 ; Beeper address
00F2AF  1               BEEP_PW			= $70		; pitch of "low" beep
00F2AF  1               BEEP_PW2		= $F0		; pitch of "high" beep
00F2AF  1               BEEP_LN			= $20
00F2AF  1               DELAY_LEN1		= $05		; Also affects pitch
00F2AF  1               BEEP_LN_CALC	= $05
00F2AF  1               
00F2AF  1               ; compact flash bits n bobs
00F2AF  1               CF_BASE			= $BFB0	; Compact flash address
00F2AF  1               CF_DATA     	= CF_BASE+0
00F2AF  1               CF_FEATURE  	= CF_BASE+1
00F2AF  1               CF_ERROR    	= CF_BASE+1
00F2AF  1               CF_SEC_CNT  	= CF_BASE+2
00F2AF  1               CF_SECTOR   	= CF_BASE+3
00F2AF  1               CF_CYL_LOW  	= CF_BASE+4
00F2AF  1               CF_CYL_HI   	= CF_BASE+5
00F2AF  1               CF_HEAD     	= CF_BASE+6
00F2AF  1               CF_STATUS   	= CF_BASE+7
00F2AF  1               CF_COMMAND  	= CF_BASE+7
00F2AF  1               CF_LBA0     	= CF_BASE+3
00F2AF  1               CF_LBA1     	= CF_BASE+4
00F2AF  1               CF_LBA2     	= CF_BASE+5
00F2AF  1               CF_LBA3     	= CF_BASE+6
00F2AF  1               
00F2AF  1               CMD_READ    	= $20
00F2AF  1               CMD_WRITE   	= $30
00F2AF  1               CMD_FEATURE 	= $EF
00F2AF  1               
00F2AF  1               CF_BUFFER 		= $04	; Start of two pages (512 bytes) of buffer
00F2AF  1               
00F2AF  1               BUFPTR      	= $40         ; Pointer to CF Read/Write Buffer (16 bit)
00F2AF  1               BUFPTRL     	= $40         ; Pointer to CF Read/Write Buffer Low Byte
00F2AF  1               BUFPTRH     	= $41         ; Pointer to CF Read/Write Buffer Low Byte
00F2AF  1               LBA_0       	= $42         ; Temp storage for LBA Byte 0
00F2AF  1               LBA_1       	= LBA_0+1     ; ... LBA Byte 1
00F2AF  1               LBA_2       	= LBA_0+2     ; ... LBA Byte 2
00F2AF  1               LBA_3       	= LBA_0+3     ; ... LBA Byte 3 (lower 4 bits only)
00F2AF  1               PAGES       	= LBA_0+4     ; Counter for number of mem pages to use
00F2AF  1               LOC				= LBA_0+5	  ; Pointer for location on CF (16 bit)
00F2AF  1               LOC_L			= LBA_0+5	  ; low byte of location on CF to save
00F2AF  1               LOC_H			= LOC_L+1	  ; low byte of location on CF to save
00F2AF  1               
00F2AF  1               CF_LB			= $0600 ; Place for low byte of sector address
00F2AF  1               CF_MB			= $0601 ; Place for middle byte of sector address
00F2AF  1               CF_HB			= $0602 ; Place for high byte of sector address
00F2AF  1               CF_LDSV			= $0603 ; Store the "are we accessing CF" variable here, used to redirect input/output
00F2AF  1               BUFF_NEWCHAR	= $604
00F2AF  1               
00F2AF  1               
00F2AF  1               
00F2AF  1               ; display addresses
00F2AF  1               DISP_DT			= $BFD0
00F2AF  1               DISP_RG			= $BFD1
00F2AF  1               DISP_WAIT		= $BFD2  ; This is the Glue logic, Bit 2 is LOW when display is busy, IGNORE all other bits
00F2AF  1               
00F2AF  1               
00F2AF  1               ; 256 byte page used for my loops and bits (away from basic)
00F2AF  1               MyDL 			= $610
00F2AF  1               MyDL2		 	= $611
00F2AF  1               MyDL3			= $612
00F2AF  1               
00F2AF  1               MyLP1			= $620
00F2AF  1               MyLP2			= $621
00F2AF  1               MyERR			= $622
00F2AF  1               
00F2AF  1               DISP_temp		= $623
00F2AF  1               DISP_ccol		= $624	; current coloumn (useful for delete)
00F2AF  1               DISP_crow		= $625	; current row (used for scrolling)
00F2AF  1               DISP_initcom	= $626
00F2AF  1               			; lines below used for plot, square, circle, line, etc
00F2AF  1               DISP_posx_h		= $627	; X position high byte
00F2AF  1               DISP_posx_l		= $628	; X position low byte
00F2AF  1               DISP_posy_h		= $629	; Y position high byte
00F2AF  1               DISP_posy_l		= $62A	; Y position low byte
00F2AF  1               DISP_posw_h		= $62B	; width high byte
00F2AF  1               DISP_posw_l		= $62C	; width low byte
00F2AF  1               DISP_posh_h		= $62D	; height high byte
00F2AF  1               DISP_posh_l		= $62E	; height low byte
00F2AF  1               DISP_col_l		= $62F	; colour for line or outline
00F2AF  1               DISP_col_t		= $630  ; colour for TEXT
00F2AF  1               DISP_fill		= $631	; fill?
00F2AF  1               DISP_dim_h		= $632
00F2AF  1               DISP_dim_l		= $632
00F2AF  1               
00F2AF  1               			; Bunch of temporary values
00F2AF  1               MyTEMP			= $650
00F2AF  1               MyTEMP2			= $651
00F2AF  1               MyTEMP3			= $652
00F2AF  1               gthan			= $653
00F2AF  1               
00F2AF  1               OutK_Y			= $655
00F2AF  1               OutK_X			= $656
00F2AF  1               
00F2AF  1               
00F2AF  1               ; now the code. all this does is set up the vectors and interrupt code
00F2AF  1               ; and wait for the user to select [C]old or [W]arm start. nothing else
00F2AF  1               ; fits in less than 128 bytes
00F2AF  1               	.segment "IOHANDLER"
00F2AF  1               	.org	$F300			; pretend this is in a 1/8K ROM
00F300  1               
00F300  1               ; reset vector points here
00F300  1               RES_vec
00F300  1  D8           	CLD				; clear decimal mode
00F301  1  A2 FF        	LDX	#$FF		; empty stack
00F303  1  9A           	TXS				; set the stack
00F304  1               
00F304  1               ; set up vectors and interrupt code, copy them to page 2
00F304  1               
00F304  1  A0 3A        	LDY	#END_CODE-LAB_vec	; set index/count
00F306  1               LAB_stlp
00F306  1  B9 E9 FC     	LDA	LAB_vec-1,Y		; get byte from interrupt code
00F309  1  99 04 02     	STA	VEC_IN-1,Y		; save to RAM
00F30C  1  88           	DEY					; decrement index/count
00F30D  1  D0 F7        	BNE	LAB_stlp		; loop if more to do
00F30F  1               
00F30F  1               ; set up 65c51
00F30F  1               ;    STA A_res       ; soft reset (value not important)
00F30F  1               ;    LDA #$0B        ; set specific modes and functions
00F30F  1                   	            ; no parity, no echo, no Tx interrupt
00F30F  1                       	        ; no Rx interrupt, enable Tx/Rx
00F30F  1               ;    STA A_cmd       ; save to command register
00F30F  1               ;    LDA #$10        ; 8-N-1, 115200 baud
00F30F  1               ;    STA A_ctl       ; set control register
00F30F  1               
00F30F  1  20 D3 F9     	JSR PWR_BEEP_LOW	; power beep
00F312  1  20 06 F4     	JSR DISP_INIT		; initialise screen
00F315  1  20 C6 F9     	JSR PWR_BEEP_HIGH	; beep after display init
00F318  1               
00F318  1               	; other bits of system init
00F318  1  A9 00        	LDA #$00
00F31A  1  8D 03 06     	STA CF_LDSV		; no redirect of input/output to CF
00F31D  1               
00F31D  1               
00F31D  1               	; Set colours
00F31D  1  A9 FC        	LDA #%11111100
00F31F  1  8D 30 06     	STA DISP_col_t
00F322  1  20 5F F5     	JSR DISP_TEXT_COLOUR_direct
00F325  1  A0 00        	LDY #$0
00F327  1               LAB_dobanner
00F327  1  B9 AE FD     	LDA	LAB_banner,Y	; get byte from sign on message
00F32A  1  C9 0D        	CMP #$0D
00F32C  1  D0 12        	BNE LAB_dobanner_char
00F32E  1  20 FF E0     	JSR	V_OUTP			; output character (CR)
00F331  1  CE 30 06     	DEC DISP_col_t		; Change colour based on row
00F334  1  CE 30 06     	DEC DISP_col_t
00F337  1  CE 30 06     	DEC DISP_col_t
00F33A  1  CE 30 06     	DEC DISP_col_t
00F33D  1  20 5F F5     	JSR DISP_TEXT_COLOUR_direct
00F340  1               
00F340  1               LAB_dobanner_char
00F340  1  C9 00        	CMP #$00
00F342  1  F0 06        	BEQ LAB_presignon	; display next message
00F344  1  20 FF E0     	JSR	V_OUTP			; output character
00F347  1  C8           	INY					; increment index
00F348  1  D0 DD        	BNE	LAB_dobanner	; loop, branch always
00F34A  1               
00F34A  1               LAB_presignon
00F34A  1  A0 00        	LDY #$0
00F34C  1  A9 E4        	LDA #%11100100
00F34E  1  8D 30 06     	STA DISP_col_t
00F351  1  20 5F F5     	JSR DISP_TEXT_COLOUR_direct
00F354  1               
00F354  1               LAB_signon				; now do the signon message, Y = $00 here
00F354  1  B9 81 FE     	LDA	LAB_mess,Y		; get byte from sign on message
00F357  1  F0 06        	BEQ KYB_msg			; display next message
00F359  1               
00F359  1  20 FF E0     	JSR	V_OUTP			; output character
00F35C  1  C8           	INY					; increment index
00F35D  1  D0 F5        	BNE	LAB_signon		; loop, branch always
00F35F  1               
00F35F  1               KYB_msg
00F35F  1  20 F8 F3     	JSR KYB_cwmmsg
00F362  1               
00F362  1               LAB_nokey
00F362  1  20 FC E0     	JSR	V_INPT			; call scan input device
00F365  1  90 FB        	BCC	LAB_nokey		; loop if no key
00F367  1               
00F367  1  20 9C F3     	JSR	ACIAout			; output character
00F36A  1               
00F36A  1  29 DF        	AND	#$DF			; mask xx0x xxxx, ensure upper case
00F36C  1  C9 57        	CMP	#'W'			; compare with [W]arm start
00F36E  1  F0 16        	BEQ	LAB_dowarm		; branch if [W]arm start
00F370  1               
00F370  1  C9 4D            CMP #'M'
00F372  1  F0 1D            BEQ LAB_dowoz
00F374  1               
00F374  1  C9 43        	CMP	#'C'			; compare with [C]old start
00F376  1  F0 03        	BEQ LAB_docold
00F378  1  4C 00 F3     	JMP RES_vec
00F37B  1               
00F37B  1               LAB_docold
00F37B  1  A9 0D        	LDA #$0D
00F37D  1  8D E0 BF     	STA A_txd			; clear keyboard screen
00F380  1  20 DC F3     	JSR KYB_basmsg
00F383  1  4C 00 C0     	JMP	LAB_COLD		; do EhBASIC cold start
00F386  1               
00F386  1               LAB_dowarm
00F386  1  A9 0D        	LDA #$0D
00F388  1  8D E0 BF     	STA A_txd			; clear keyboard screen
00F38B  1  20 DC F3     	JSR KYB_basmsg
00F38E  1  4C 00 00     	JMP	LAB_WARM		; do EhBASIC warm start
00F391  1               LAB_dowoz
00F391  1  A9 0D        	LDA #$0D
00F393  1  8D E0 BF     	STA A_txd			; clear keyboard screen
00F396  1  20 EA F3     	JSR KYB_wozmsg
00F399  1  4C 00 F0         JMP EWOZ
00F39C  1               
00F39C  1               ; byte out to simulated ACIA
00F39C  1               ACIAout
00F39C  1  48           	PHA
00F39D  1               
00F39D  1               SWait:
00F39D  1  AD F0 BF     	LDA	ACIAStatus
00F3A0  1  29 02        	AND	#2
00F3A2  1  C9 02        	CMP	#2
00F3A4  1  D0 F7        	BNE	SWait
00F3A6  1  68           	PLA
00F3A7  1  8D F1 BF     	STA	ACIAData
00F3AA  1               
00F3AA  1               	; Send output to display
00F3AA  1  48           	PHA
00F3AB  1  20 95 F5     	JSR DISP_TEXT_WR
00F3AE  1  68           	PLA
00F3AF  1               
00F3AF  1               ACIAout_exit
00F3AF  1               ; end of screen output code
00F3AF  1  60           	RTS						; end of ACIAout
00F3B0  1               
00F3B0  1               
00F3B0  1               
00F3B0  1               
00F3B0  1               
00F3B0  1               ; byte in from simulated ACIA
00F3B0  1               
00F3B0  1               ; byte out to keyboard 65c51
00F3B0  1               KEYBout
00F3B0  1  8D E0 BF     	STA A_txd			; send character to keyboard display
00F3B3  1  48           	PHA					; save A
00F3B4  1               
00F3B4  1  A9 FF        	LDA #$FF
00F3B6  1  8D 10 06     	STA MyDL
00F3B9  1               KEYDL				; Outer loop
00F3B9  1  A9 40        	LDA #$40
00F3BB  1  8D 11 06     	STA MyDL2
00F3BE  1               KEYDL2				; Inner loop
00F3BE  1  CE 11 06     	DEC MyDL2
00F3C1  1  D0 FB        	BNE	KEYDL2
00F3C3  1               
00F3C3  1  CE 10 06     	DEC MyDL
00F3C6  1  D0 F1        	BNE KEYDL		; if not 0 increment more
00F3C8  1               
00F3C8  1  68           	PLA
00F3C9  1  60           	RTS
00F3CA  1               
00F3CA  1               LAB_WAIT_Rx
00F3CA  1               ;    LDA A_sts       ; get ACIA status
00F3CA  1               ;    AND #$08        ; mask rx buffer status flag
00F3CA  1               ;    BEQ LAB_WAIT_Rx ; loop if rx buffer empty
00F3CA  1               
00F3CA  1               ;    LDA A_rxd       ; get byte from ACIA data port
00F3CA  1               
00F3CA  1               
00F3CA  1               ; byte in from simulated ACIA (CONSOLE) or Keyboard
00F3CA  1               ACIAin
00F3CA  1  AD F0 BF     	LDA	ACIAStatus
00F3CD  1  29 01        	AND	#1
00F3CF  1  C9 01        	CMP	#1
00F3D1  1  D0 05        	BNE	NoDataIn
00F3D3  1  AD F1 BF     	LDA	ACIAData
00F3D6  1  38           	SEC		; Carry set if key available
00F3D7  1  60           	RTS
00F3D8  1               NoDataIn:	; nothing from console port
00F3D8  1  18           	CLC		; Carry clear if no key pressed
00F3D9  1               
00F3D9  1               KEY_RX		; we get here if there is no data from console
00F3D9  1               ;    LDA A_sts       ; get ACIA status
00F3D9  1               ;    AND #$08        ; mask rx buffer status flag
00F3D9  1               ;    BEQ KEYB_NoData ; skip if rx buffer empty
00F3D9  1               
00F3D9  1               ;    LDA A_rxd       ; get byte from ACIA data port
00F3D9  1               ;	SEC				; Carry set if key available
00F3D9  1  60           	RTS
00F3DA  1               
00F3DA  1               KEYB_NoData
00F3DA  1  18           	CLC				; Carry clear if no key pressed
00F3DB  1  60           	RTS
00F3DC  1               
00F3DC  1               
00F3DC  1               ; Show "EhBASIC " on keyboard display
00F3DC  1               KYB_basmsg
00F3DC  1  A0 00        	LDY #$00
00F3DE  1               
00F3DE  1               KYB_basmsg_lp
00F3DE  1  B9 AA FE     	LDA KYB_basmess_str,Y
00F3E1  1  F0 06        	BEQ	KYB_basmsg_exit	; exit loop if done
00F3E3  1               
00F3E3  1  20 B0 F3     	JSR KEYBout			;
00F3E6  1  C8           	INY					; increment index
00F3E7  1  D0 F5        	BNE KYB_basmsg_lp	; loop, always
00F3E9  1               
00F3E9  1               KYB_basmsg_exit
00F3E9  1  60           	RTS
00F3EA  1               
00F3EA  1               ; Show "eWOZMON " on keyboard display
00F3EA  1               KYB_wozmsg
00F3EA  1  A0 00        	LDY #$00
00F3EC  1               
00F3EC  1               KYB_wozmsg_lp
00F3EC  1  B9 B5 FE     	LDA KYB_wozmess_str,Y
00F3EF  1  F0 06        	BEQ	KYB_wozmsg_exit	; exit loop if done
00F3F1  1               
00F3F1  1  20 B0 F3     	JSR KEYBout			;
00F3F4  1  C8           	INY					; increment index
00F3F5  1  D0 F5        	BNE KYB_wozmsg_lp	; loop, always
00F3F7  1               
00F3F7  1               KYB_wozmsg_exit
00F3F7  1  60           	RTS
