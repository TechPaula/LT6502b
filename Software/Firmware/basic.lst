00FB6B  1               IO_DIR_read_lp
00FB6B  1  A9 04        	LDA #$04
00FB6D  1  85 41        	STA BUFPTRH
00FB6F  1  A9 00        	LDA #$00
00FB71  1  85 40        	STA BUFPTRL
00FB73  1               
00FB73  1  20 00 FC     	JSR CF_SET_LBA
00FB76  1  20 30 FC     	JSR CF_READ_SECTOR
00FB79  1               
00FB79  1               	; "TICK" whilst scanning
00FB79  1  A9 FC        	LDA #$FC
00FB7B  1  8D 50 06     	STA MyTEMP
00FB7E  1  A9 01        	LDA #$01
00FB80  1  85 20        	STA BEEP_LN
00FB82  1  20 F3 F9     	JSR VARI_BEEP
00FB85  1               
00FB85  1               	; Check slot has valid data, if not skip it
00FB85  1  AD 00 04     	LDA $0400
00FB88  1               
00FB88  1  C9 20        	CMP #$20
00FB8A  1  30 35        	BMI IO_DIR_nextslot
00FB8C  1  AD 00 04     	LDA $0400
00FB8F  1  C9 7E        	CMP #$7E
00FB91  1  10 2E        	BPL IO_DIR_nextslot
00FB93  1               
00FB93  1               	; print slot number
00FB93  1  A5 44        	LDA LBA_2
00FB95  1  A6 43        	LDX LBA_1
00FB97  1  20 92 DA     	JSR LAB_295E
00FB9A  1               
00FB9A  1               	; seperator
00FB9A  1  A9 20        	LDA #$20
00FB9C  1  20 FF E0     	JSR V_OUTP
00FB9F  1  A9 2D        	LDA #$2D
00FBA1  1  20 FF E0     	JSR V_OUTP
00FBA4  1  A9 20        	LDA #$20
00FBA6  1  20 FF E0     	JSR V_OUTP
00FBA9  1               
00FBA9  1               	; print slot name
00FBA9  1               IO_DIR_showname
00FBA9  1  A0 00        	LDY #$00
00FBAB  1               IO_DIR_showname_lp
00FBAB  1  B9 00 04     	LDA $0400,Y
00FBAE  1  20 FF E0     	JSR V_OUTP
00FBB1  1  C8           	INY
00FBB2  1  98           	TYA
00FBB3  1  C9 10        	CMP #$10
00FBB5  1  D0 F4        	BNE IO_DIR_showname_lp
00FBB7  1               
00FBB7  1  A9 0D        	LDA #$0D
00FBB9  1  20 FF E0     	JSR V_OUTP
00FBBC  1  A9 0A        	LDA #$0A
00FBBE  1  20 FF E0     	JSR V_OUTP
00FBC1  1               
00FBC1  1               IO_DIR_nextslot
00FBC1  1  18           	CLC
00FBC2  1  A5 43        	LDA LBA_1
00FBC4  1  69 01        	ADC #$01
00FBC6  1  85 43        	STA LBA_1
00FBC8  1               
