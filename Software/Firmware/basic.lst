00E147  2               
00E147  2  C9 3A              CMP   #':'              ; compare with ":"
00E149  2  B0 0A              BCS   LAB_2D05          ; exit if >= ":", not numeric, carry set
00E14B  2               
00E14B  2  C9 20              CMP   #' '              ; compare with " "
00E14D  2  F0 EB              BEQ   LAB_2CEE          ; if " " go do next
00E14F  2               
00E14F  2  38                 SEC                     ; set carry for SBC
00E150  2  E9 30              SBC   #'0'              ; subtract "0"
00E152  2  38                 SEC                     ; set carry for SBC
00E153  2  E9 D0              SBC   #$D0              ; subtract -"0"
00E155  2                                             ; clear carry if byte = "0"-"9"
