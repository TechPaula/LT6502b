00FBE6  1               
00FBE6  1               ;-------------------------------------------------------------------------------
00FBE6  1               ; CF_INIT - Set 8 bit mode, write 1 to feature register
00FBE6  1               ;			then $EF to command register to execute
00FBE6  1               ;-------------------------------------------------------------------------------
00FBE6  1               CF_INIT:
00FBE6  1  5A               PHY
00FBE7  1  DA               PHX
00FBE8  1  48               PHA
00FBE9  1  20 FA FB         JSR     CF_WAIT
00FBEC  1  A9 01            LDA     #$01
00FBEE  1  8D B1 BF         STA     CF_FEATURE
00FBF1  1  A9 EF            LDA     #CMD_FEATURE
00FBF3  1  8D B7 BF         STA     CF_COMMAND
00FBF6  1  68               PLA
00FBF7  1  FA               PLX
00FBF8  1  7A               PLY
00FBF9  1  60               RTS
00FBFA  1               
00FBFA  1               
00FBFA  1               
00FBFA  1               
00FBFA  1               
00FBFA  1               
00FBFA  1               
00FBFA  1               
00FBFA  1               ;-------------------------------------------------------------------------------
00FBFA  1               ; CF_WAIT - Checks the CF card isn't busy
00FBFA  1               ;
00FBFA  1               ; Wait for flag MSB of status register to be clear
00FBFA  1               ;
00FBFA  1               ; TODO - Implement time out?
00FBFA  1               ;
00FBFA  1               ;-------------------------------------------------------------------------------
00FBFA  1               CF_WAIT:
00FBFA  1  AD B7 BF         LDA     CF_STATUS
00FBFD  1  30 FB            BMI     CF_WAIT
00FBFF  1  60               RTS
00FC00  1               
00FC00  1               
00FC00  1               
00FC00  1               ;-------------------------------------------------------------------------------
00FC00  1               ; CF_SET_LBA - Sets up the CF Card with LBA and Sector Count parameters
00FC00  1               ;
00FC00  1               ; LBA values are read from Zero Page at $42(LBA0) to $45(LBA3)
00FC00  1               ;
00FC00  1               ; Sector count is always 1
00FC00  1               ;
00FC00  1               ;-------------------------------------------------------------------------------
00FC00  1               CF_SET_LBA:
00FC00  1  20 FA FB         JSR     CF_WAIT
00FC03  1               
00FC03  1                   ; SET ONE SECTOR (512 BYTES) AT A TIME
00FC03  1  A9 01            LDA     #$01
00FC05  1  8D B2 BF         STA     CF_SEC_CNT
00FC08  1  20 FA FB         JSR     CF_WAIT
00FC0B  1               
00FC0B  1               
00FC0B  1  A5 42            LDA     LBA_0           ; Lower Byte
00FC0D  1  8D B3 BF         STA     CF_LBA0
00FC10  1  20 FA FB         JSR     CF_WAIT
00FC13  1               
00FC13  1  A5 43            LDA     LBA_1           ; Lower Middle Byte
00FC15  1  8D B4 BF         STA     CF_LBA1
00FC18  1  20 FA FB         JSR     CF_WAIT
00FC1B  1               
00FC1B  1  A5 44            LDA     LBA_2           ; Upper Middle Byte
00FC1D  1  8D B5 BF         STA     CF_LBA2
00FC20  1  20 FA FB         JSR     CF_WAIT
00FC23  1               
00FC23  1  A5 45            LDA     LBA_3           ; Upper Nybble
00FC25  1  29 0F            AND     #$0F            ; Ensure top 4 bits are 0000
00FC27  1  09 E0            ORA     #$E0            ; Then force top 4 bits to 1110
00FC29  1  8D B6 BF         STA     CF_LBA3
00FC2C  1  20 FA FB         JSR     CF_WAIT
00FC2F  1  60               RTS
00FC30  1               
00FC30  1               
00FC30  1               ;-------------------------------------------------------------------------------
00FC30  1               ; CF_READ_SECTOR - Reads a single sector from CF into a buffer
00FC30  1               ;
00FC30  1               ; Buffer address should always be page aligned. Set BUFPTRL to 0, and
00FC30  1               ; BUFPTRH to high byte of buffer address
00FC30  1               ; Set number of memory pages to use for buffer in PAGES, default = 2
00FC30  1               ;
00FC30  1               ;-------------------------------------------------------------------------------
00FC30  1               CF_READ_SECTOR:
00FC30  1  20 00 FC         JSR     CF_SET_LBA
00FC33  1  20 FA FB         JSR     CF_WAIT
00FC36  1               
00FC36  1  A9 20            LDA     #CMD_READ           ; Send the Read command to the CF
00FC38  1  8D B7 BF         STA     CF_COMMAND
00FC3B  1  20 FA FB         JSR     CF_WAIT             ; de dum de dum
00FC3E  1               
00FC3E  1  A9 02            LDA     #$02                ; Set page count to 2
00FC40  1  85 46            STA     PAGES
00FC42  1               
00FC42  1  A0 00            LDY     #$00                ; Clear Y
00FC44  1               
00FC44  1               CF_RD_LP1:
00FC44  1  AD B0 BF         LDA     CF_DATA             ; Read CF Data Register
00FC47  1  91 40            STA     (BUFPTRL),Y         ; Save to buffer
00FC49  1               
00FC49  1  C8               INY                         ; Increment buffer pointer
00FC4A  1  D0 F8            BNE     CF_RD_LP1           ; If it's zero, we need a new page, otherwise repeat
00FC4C  1               
00FC4C  1  E6 41            INC     BUFPTRH             ; Increment the high byte of the buffer pointer
00FC4E  1                                               ; (So subsequent reads don't need to set up pointer)
00FC4E  1               
00FC4E  1  C6 46            DEC     PAGES               ; decrement page counter
00FC50  1  F0 04            BEQ     CF_RD_EXIT          ; if it's zero, we're done, so exit
00FC52  1               
00FC52  1  A0 00            LDY     #$00                ; Clear Y (it should be already, but JFDI)
00FC54  1  80 EE            BRA     CF_RD_LP1           ; and repeat for another 256 bytes
00FC56  1               
00FC56  1               CF_RD_EXIT:
00FC56  1  60               RTS
00FC57  1               
00FC57  1               ;-------------------------------------------------------------------------------
00FC57  1               ; CF_WRITE_SECTOR - writes a single sector from buffer into a CF
00FC57  1               ;
00FC57  1               ; Buffer address should always be page aligned. Set BUFPTRL to 0, and
00FC57  1               ; BUFPTRH to high byte of buffer address
00FC57  1               ; Set number of memory pages to use for buffer in PAGES, default = 2
00FC57  1               ;-------------------------------------------------------------------------------
00FC57  1               CF_WRITE_SECTOR:
00FC57  1  20 00 FC         JSR     CF_SET_LBA
00FC5A  1  20 FA FB         JSR     CF_WAIT
00FC5D  1               
00FC5D  1  A9 30            LDA     #CMD_WRITE          ; Send the Read command to the CF
00FC5F  1  8D B7 BF         STA     CF_COMMAND
00FC62  1  20 FA FB         JSR     CF_WAIT             ; de dum de dum;
00FC65  1               
00FC65  1  A9 02            LDA     #$02                ; Set page count to 2
00FC67  1  85 46            STA     PAGES
00FC69  1               
00FC69  1  A0 00            LDY     #$00                ; Clear Y
00FC6B  1               
00FC6B  1               CF_WR_LP1:
00FC6B  1  B1 40            LDA     (BUFPTRL),Y         ; Read from buffer
00FC6D  1  8D B0 BF         STA     CF_DATA             ; Write to CF Data Register
00FC70  1               
00FC70  1  C8               INY                         ; Increment buffer pointer
00FC71  1  D0 F8            BNE     CF_WR_LP1           ; If it's zero, we need a new page, otherwise repeat
00FC73  1               
00FC73  1  E6 41            INC     BUFPTRH             ; Increment the high byte of the buffer pointer
00FC75  1                                               ; (So subsequent writes don't need to set pointer)
00FC75  1               
00FC75  1  C6 46            DEC     PAGES               ; decrement page counter
00FC77  1  F0 04            BEQ     CF_WR_EXIT          ; if it's zero, we're done, so exit
00FC79  1               
00FC79  1               
00FC79  1  A0 00            LDY     #$00                ; Clear Y (it should be already, but JFDI)
00FC7B  1  80 EE            BRA     CF_WR_LP1           ; and repeat for another 256 bytes
00FC7D  1               
00FC7D  1               CF_WR_EXIT:
00FC7D  1  60               RTS
00FC7E  1               
00FC7E  1               ;-------------------------------------------------------------------------------
00FC7E  1               ; CLR_CFBUFFER - Clears the Compact Flash read/write buffer
00FC7E  1               ;
00FC7E  1               ; Buffer address should always be page aligned. Set BUFPTRL to 0, and
00FC7E  1               ; BUFPTRH to high byte of buffer address
00FC7E  1               ; Set number of memory pages to clear in PAGES
00FC7E  1               ;
00FC7E  1               ;-------------------------------------------------------------------------------
00FC7E  1                CLR_CFBUFFER:
00FC7E  1               
00FC7E  1  A0 00            LDY     #$00            ; Set offset to 0
00FC80  1               
00FC80  1  A9 00            LDA     #$00            ; Value to write
00FC82  1               CLRLOOP:
00FC82  1  91 40            STA     (BUFPTR),Y      ; Write data to memory
00FC84  1  C8               INY                     ; Point to next byte
00FC85  1  D0 FB            BNE     CLRLOOP         ; do it 256 times
00FC87  1               
00FC87  1  C6 46            DEC     PAGES           ; Check if all done
00FC89  1  F0 06            BEQ     CLRDONE         ; if so, exit
00FC8B  1               
00FC8B  1  A0 00            LDY     #$00            ; if not, clear offset again
00FC8D  1  E6 41            INC     BUFPTRH         ; Increment page counter
00FC8F  1  80 F1            BRA     CLRLOOP         ; and repeat
00FC91  1               CLRDONE:
00FC91  1  60               RTS
00FC92  1               
00FC92  1               
00FC92  1               
00FC92  1               
00FC92  1               
00FC92  1               
00FC92  1               ; ------ END compact flash
00FC92  1               
00FC92  1               
00FC92  1               ; ----- OUTK send text to keyboard display
00FC92  1               ;			we always print to the next character, don't need ; or ,
00FC92  1               ;			CRLF is not auto sent
00FC92  1               OUTK
00FC92  1  5A           	PHY
00FC93  1  DA           	PHX
00FC94  1  48           	PHA
00FC95  1               
00FC95  1               	; send result to keyboard
00FC95  1  20 E4 CA         JSR LAB_EVEX        ; evaluate expression
00FC98  1  24 5F            BIT Dtypef          ; test data type flag, $FF=string, $00=numeric
00FC9A  1  30 1B            BMI OUTK_string     ; branch if string
00FC9C  1  20 A5 DA     	JSR LAB_296E        ; convert FAC1 to string
00FC9F  1               
00FC9F  1  A0 00        	LDY #$00			; Reset offset
00FCA1  1               OUTK_lp
00FCA1  1  B9 F0 00     	LDA $00F0,Y			; Read string
00FCA4  1  C9 00        	CMP #$00
00FCA6  1  F0 0B        	BEQ OUTK_exit		; if end of string, exit
00FCA8  1  C9 20        	CMP #$20
00FCAA  1  F0 03        	BEQ OUTK_skip		; if " " then skip
00FCAC  1  20 B0 F3     	JSR KEYBout			; send character
00FCAF  1               
00FCAF  1               OUTK_skip
00FCAF  1  C8           	INY
00FCB0  1  4C A1 FC     	JMP OUTK_lp
00FCB3  1               
00FCB3  1               OUTK_exit
00FCB3  1  68           	PLA
00FCB4  1  FA           	PLX
00FCB5  1  7A           	PLY
00FCB6  1  60           	RTS
00FCB7  1               
00FCB7  1               OUTK_string
00FCB7  1  A9 0D        	LDA #$0D				; Clear the display BEFORE sending text
00FCB9  1  20 B0 F3     	JSR KEYBout
00FCBC  1               
00FCBC  1  20 55 D3     	JSR LAB_22B6        ; pop string off descriptor stack, or from top of string
00FCBF  1               						; space returns with A = length, X=$71=pointer low byte,
00FCBF  1               						; Y=$72=pointer high byte
00FCBF  1  A0 00        	LDY #$00           	; reset index
00FCC1  1  AA           	TAX                 ; copy length to X
00FCC2  1  F0 EF        	BEQ OUTK_exit       ; exit (RTS) if null string
00FCC4  1               
00FCC4  1               OUTK_string_loop
00FCC4  1  B1 71        	LDA (ut1_pl),Y     		; get next byte
00FCC6  1  20 B0 F3     	JSR KEYBout          	; go print the character
00FCC9  1  C8           	INY                     ; increment index
00FCCA  1  CA           	DEX                     ; decrement count
00FCCB  1  D0 F7        	BNE OUTK_string_loop  	; loop if not done yet
00FCCD  1               
00FCCD  1  4C B3 FC     	JMP OUTK_exit
00FCD0  1               ; ----- END OF OUTK
00FCD0  1               
00FCD0  1               
00FCD0  1               ; Delay loop for random things
00FCD0  1               DELAY1
00FCD0  1  A9 05        	LDA #DELAY_LEN1
00FCD2  1  8D 12 06     	STA MyDL3
00FCD5  1               
00FCD5  1               DELAY1_LP
00FCD5  1  CE 12 06     	DEC MyDL3
00FCD8  1  D0 FB        	BNE DELAY1_LP
00FCDA  1               
00FCDA  1  60           	RTS
00FCDB  1               
00FCDB  1               DELAY2
00FCDB  1  A9 05        	LDA #DELAY_LEN1
00FCDD  1  8D 12 06     	STA MyDL3
00FCE0  1               
00FCE0  1               DELAY2_LP
00FCE0  1  EA           	NOP
00FCE1  1  EA           	NOP
00FCE2  1  EA           	NOP
00FCE3  1  EA           	NOP
00FCE4  1  CE 12 06     	DEC MyDL3
00FCE7  1  D0 EC        	BNE DELAY1_LP
00FCE9  1               
00FCE9  1  60           	RTS
