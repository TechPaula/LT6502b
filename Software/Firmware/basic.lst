00FCFC  1  58 F5        	.word	DISP_TEXT_COLOUR	; COLOUR vector					EhBASIC = V_COLOUR
00FCFE  1  26 F7        	.word	DISP_PLOT			; PLOT vector					EhBASIC = V_PLOT
00FD00  1  AA F7        	.word	DISP_CIRCLE			; CIRCLE vector					EhBASIC = V_CIRCLE
00FD02  1  66 F8        	.word	DISP_LINE			; LINE vector					EhBASIC = V_LINE
00FD04  1  8D F8        	.word	DISP_SQUARE			; SQUARE vector					EhBASIC = V_SQUARE
00FD06  1  C6 F8        	.word	DISP_ELIPSE			; ELIPSE vector					EhBASIC = V_ELIPSE
00FD08  1  3C F9        	.word	DISP_TRIANGLE		; TRIANGLE vector				EhBASIC = V_TRIANGLE
00FD0A  1  74 F4        	.word 	DISP_MOVE_CURSOR 	; MOVECursor					EhBASIC = V_MOVEC
00FD0C  1  92 FC        	.word 	OUTK				; OUTK vector					EhBASIC = V_OUTK
00FD0E  1  99 F4        	.word 	DISP_TEXT_MODE 		; set display back to text mode EhBASIC = V_TEXTMODE
00FD10  1               
00FD10  1               ; EhBASIC IRQ support
00FD10  1               IRQ_CODE
00FD10  1  48           	PHA				; save A
00FD11  1  A5 DF        	LDA	IrqBase		; get the IRQ flag byte
00FD13  1  4A           	LSR				; shift the set b7 to b6, and on down ...
00FD14  1  05 DF        	ORA	IrqBase		; OR the original back in
00FD16  1  85 DF        	STA	IrqBase		; save the new IRQ flag byte
00FD18  1  68           	PLA				; restore A
00FD19  1  40           	RTI
00FD1A  1               
00FD1A  1               ; EhBASIC NMI support
00FD1A  1               NMI_CODE
00FD1A  1  48           	PHA				; save A
00FD1B  1  A5 DC        	LDA	NmiBase		; get the NMI flag byte
00FD1D  1  4A           	LSR				; shift the set b7 to b6, and on down ...
00FD1E  1  05 DC        	ORA	NmiBase		; OR the original back in
00FD20  1  85 DC        	STA	NmiBase		; save the new NMI flag byte
00FD22  1  68           	PLA				; restore A
00FD23  1  40           	RTI
