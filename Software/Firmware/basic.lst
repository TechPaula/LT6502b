00FCEC  1  9C F3        	.word	ACIAout				; byte out to simulated ACIA   	EhBASIC = V_OUTP
00FCEE  1  2B FA        	.word	IO_LOAD				; load vector for EhBASIC		EhBASIC = V_LOAD
00FCF0  1  CE FA        	.word	IO_SAVE				; save vector for EhBASIC		EhBASIC = V_SAVE
00FCF2  1  5E FB        	.word   IO_DIR				; dir vector for EhBASIC		EhBASIC = V_DIR
00FCF4  1  98 F9        	.word 	IO_CLS				; CLS vector for EhBASIC		EhBASIC = V_CLS
00FCF6  1  24 F6        	.word	IO_MODE				; MODE vector for EhBASIC		EhBASIC = V_MODE
00FCF8  1  9C F9        	.word   BEEP_CMD			; BEEP vector for EhBASIC		EhBASIC = V_BEEP
