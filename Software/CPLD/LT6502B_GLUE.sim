%END

%FIELD
FIELD Address = A15,A14,A13,A12,A11,A10,A9,A8,A7,A6,A5,A4,A3,A2,A1,A0
%END

%EQUATION
ACIA_nCS =>
    !A4 & A5 & A6 & A7 & A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15 & PHI2

BEEPER =>
    BEEPER & D2
  # BEEPER & !PHI2
  # !A15 & BEEPER
  # A14 & BEEPER
  # !A13 & BEEPER
  # !A12 & BEEPER
  # !A11 & BEEPER
  # !A10 & BEEPER
  # !A9 & BEEPER
  # !A8 & BEEPER
  # !A7 & BEEPER
  # A6 & BEEPER
  # !A5 & BEEPER
  # A4 & BEEPER
  # !A4 & A5 & !A6 & A7 & A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15 & D2 & PHI2

BEEP_CS =>
    !A4 & A5 & !A6 & A7 & A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15 & PHI2

BEEP_R =>
    !A4 & A5 & !A6 & A7 & A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15 & !D2 & PHI2

BEEP_S =>
    !A4 & A5 & !A6 & A7 & A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15 & D2 & PHI2

CF_nCS =>
    A4 & A5 & !A6 & A7 & A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15

CF_nRES =>
    RESET

CLK_OUT =>
    CLK

D0 =>
    !RXF

D0.oe  =>
    !A0 & A4 & A5 & A6 & A7 & A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15 & PHI2 & RnW

D1 =>
    !TXE

D1.oe  =>
    !A0 & A4 & A5 & A6 & A7 & A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15 & PHI2 & RnW

D2 =>
    DISP_nWT

D2.oe  =>
    A1 & DISP_nCS

DISP_BL =>
    1 

DISP_DATA_EN =>
    !A1 & DISP_nCS

DISP_E =>
    !A1 & DISP_nCS & PHI2 & !Q0

DISP_nCS =>
    A4 & !A5 & A6 & A7 & A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15 & PHI2

DISP_nRES =>
    RESET

FT_CS =>
    A4 & A5 & A6 & A7 & A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15 & PHI2

KEYMOD_RnW =>
    RnW

LED =>
    CLK

LED_PWM =>
    0 

MODEM_nCS =>
    1 

MODEM_nRES =>
    RESET

PHI2.d  =>
    !PHI2
  # PHI2 & !Q2
  # PHI2 & !Q1
  # PHI2 & !Q0

PHI2.ar  =>
    RESET

PHI2.ck  =>
    CLK

Q0.d  =>
    !PHI2
  # PHI2 & !Q0

Q0.ar  =>
    RESET

Q0.ck  =>
    CLK

Q1.d  =>
    !DISP_nCS & !PHI2
  # PHI2 & Q0 & !Q1
  # PHI2 & !Q0 & Q1

Q1.ar  =>
    RESET

Q1.ck  =>
    CLK

Q2.d  =>
    !ACIA_nCS & !MODEM_nCS & !PHI2 & !SID_nCS
  # PHI2 & !Q1 & Q2
  # PHI2 & !Q0 & Q2
  # PHI2 & Q0 & Q1 & !Q2

Q2.ar  =>
    RESET

Q2.ck  =>
    CLK

RAM_nCS0 =>
    !A15

RAM_nCS1 =>
    !A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15 & PHI2
  # !A10 & A12 & !A14 & A15 & PHI2
  # !A11 & !A12 & !A14 & A15 & PHI2
  # A9 & A10 & A11 & A12 & !A13 & !A14 & A15 & PHI2
  # A10 & !A11 & A12 & !A14 & A15 & PHI2
  # !A10 & A11 & !A12 & !A14 & A15 & PHI2
  # A9 & A10 & A11 & !A12 & !A14 & A15 & PHI2
  # !A9 & A10 & A11 & !A14 & A15 & PHI2

RD =>
    !A15 & PHI2 & RnW
  # A14 & PHI2 & RnW
  # !A13 & PHI2 & RnW
  # !A12 & PHI2 & RnW
  # !A11 & PHI2 & RnW
  # !A10 & PHI2 & RnW
  # !A9 & PHI2 & RnW
  # !A8 & PHI2 & RnW
  # !A7 & PHI2 & RnW
  # !A6 & PHI2 & RnW
  # !A4 & PHI2 & RnW
  # !A5 & PHI2 & RnW

RD_FT =>
    A0 & A4 & A5 & A6 & A7 & A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15 & PHI2 & RnW

ROM_nCS =>
    1 

ROM_nR =>
    A14 & A15

RW =>
    !A15 & PHI2 & !RnW
  # A14 & PHI2 & !RnW
  # !A13 & PHI2 & !RnW
  # !A12 & PHI2 & !RnW
  # !A11 & PHI2 & !RnW
  # !A10 & PHI2 & !RnW
  # !A9 & PHI2 & !RnW
  # !A8 & PHI2 & !RnW
  # !A7 & PHI2 & !RnW
  # !A6 & PHI2 & !RnW
  # !A4 & PHI2 & !RnW
  # !A5 & PHI2 & !RnW

SID_nCS =>
    1 

VIA_nCS =>
    !A4 & !A5 & A6 & A7 & A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15

WR_FT =>
    A0 & A4 & A5 & A6 & A7 & A8 & A9 & A10 & A11 & A12 & A13 & !A14 & A15 & PHI2 & !RnW

%END
