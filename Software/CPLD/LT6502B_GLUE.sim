PIN   7 =  A15 
PIN  77 = !ACIA_nCS 
PIN  92 =  BEEPER 
PIN  29 = !CF_nCS 
PIN  28 = !CF_nRES 
PIN  87 =  CLK 
PIN  83 =  CLK_OUT 
PIN  60 =  D0 
PIN  58 =  D1 
PIN  57 =  D2 
PIN  56 =  D3 
PIN  55 =  D4 
PIN  54 =  D5 
PIN  53 =  D6 
PIN  52 =  D7 
PIN   6 =  DISP_BL 
PIN  27 =  DISP_DATA_EN 
PIN 100 =  DISP_E 
PIN   2 =  DISP_INT 
PIN  98 = !DISP_nCS 
PIN  99 = !DISP_nRES 
PIN   5 =  DISP_nWT 
PIN  71 =  KEYMOD_RnW 
PIN  94 = !LED 
PIN  30 =  LED_PWM 
PIN  97 = !MODEM_nCS 
PIN  31 = !MODEM_nRES 
PIN  75 =  PHI2 
PIN  84 =  Q0 
