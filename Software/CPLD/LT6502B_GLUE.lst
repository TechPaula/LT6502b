 10:
 11:/*********************************************************
 12: *                     INPUT PINS                        *
 13: *********************************************************/
 14:
 15:
 16:/* SYSTEM signals */
 17:Pin 87 = CLK;       /* MAIN OSC CLOCK IN */
 18:Pin 93 = !RESET;    /* GLOBAL RESET IN */
 19:Pin 84 = Q0;        /* Doesn't go anywhere, legacy from LT6502 */
 20:Pin 83 = CLK_OUT;   /* same speed as CPU unstretched, sent to VIA */
 21:
 22:
 23:Pin 37 = !RD;       /* OUTPUT */
 24:Pin 36 = !RW;       /* OUTPUT */
 25:
 26:Pin 94 = !LED;      /* Test LED output */
 27:
 28:
 29:/* CPU signals */
 30:Pin 75 = PHI2;      /* CPU_CLK OUTPUT */
 31:Pin 90 = RnW;       /* INPUT */
 32:
 33:
 34:/* ROM Enables */
 35:Pin 45 = !ROM_nR;    /* OUTPUT */
 36:Pin 46 = !ROM_nCS;   /* OUTPUT to speed things up, tie this low and just use nR */
 37:
 38:
 39:/* RAM CS */
 40:Pin 79 = !RAM_nCS0;    /* OUTPUT */
 41:Pin 78 = !RAM_nCS1;    /* OUTPUT */
 42:
 43:
 44:/* FT245, Console, Signals */
 45:Pin 48 = !RD_FT;           /* OUTPUT */
 46:Pin 47 = WR_FT;            /* OUTPUT */
 47:Pin 49 = RXF;                /* BIT 0 of 6850 register, INPUT */
 48:Pin 50 = TXE;                /* BIT 1 of 6850 register, INPUT */
 49:                           /* Had to swap pin 49/50, Labels swapped on schematic, DOH! */
 50:
 51:/* 65C22 VIA */
 52:Pin 33 = !VIA_nCS;
 53:

