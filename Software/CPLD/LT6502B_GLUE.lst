 54:
 55:/* Compact Flash */
 56:Pin 28 = !CF_nRES;       /* OUT, was nCS, but I swapped pins on the schematic, DOH! */
 57:Pin 29 = !CF_nCS;        /* OUT, was nRES, but I swapped pins on the schematic, DOH! */
 58:
 59:
 60:/* Keyboard Serial port & MODEM via atmega644 */
 61:Pin 77 = !ACIA_nCS;
 62:Pin 97 = !MODEM_nCS;
 63:Pin 31 = !MODEM_nRES;
 64:Pin 71 = KEYMOD_RnW;
 65:
 66:
 67:/* nanoSWIN SID */
 68:Pin 96 = !SID_nCS;
 69:
 70:
 71:/* Keyboard LEDs */
 72:Pin 30 = LED_PWM;         /* PWM for keyboard LEDs */
 73:
 74:
 75:/* Display */
 76:Pin 98 = !DISP_nCS;
 77:Pin 99 = !DISP_nRES;
 78:Pin 27 = DISP_DATA_EN;    /* OUT, databus level shifter enable */
 79:Pin  6 = DISP_BL;
 80:Pin 100 = DISP_E;         /* OUT, 6800 "E" signal */
 81:Pin 5 = DISP_nWT;
 82:Pin 2 = DISP_INT;         /* INPUT, from display, unused */
 83:
 84:
 85:/* Beeper */
 86:Pin 92 = BEEPER;
 87:
 88:
 89:/* Address bus all are INPUT */
 90:Pin 19 = A0;
 91:Pin 20 = A1;
 92:Pin 21 = A2;
 93:Pin 22 = A3;
 94:Pin 23 = A4;
 95:Pin 24 = A5;
 96:Pin 25 = A6;
 97:Pin 17 = A7;
 98:Pin 16 = A8;
 99:Pin 14 = A9;
100:Pin 13 = A10;
101:Pin 12 = A11;
102:Pin 10 = A12;
103:Pin  9 = A13;
104:Pin  8 = A14;
105:Pin  7 = A15;
106:
107:

