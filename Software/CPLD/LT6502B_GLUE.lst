216:
217:
218:/* MODEM */
219:MODEM_nCS = 'b'1;
220:MODEM_nRES = RESET;
221:KEYMOD_RnW = RnW;      /* needed for both keyboard and Modem */
222:
223:/* SID */
224:SID_nCS = 'b'1;
225:
226:/* LED brightness */
227:LED_PWM = 'b'0;
228:
229:
230:/* ROM 0xC000 - 0xFFFF */
231:ROM_nR  = A15 & A14;   /* ROM Read address */
232:ROM_nCS = 'b'1;        /* ROM chip select always active */
233:
234:
235:/* RAM bank 0 0x0000 - 0x7FFF */                        
236:RAM_nCS0 = !A15;        
237:
238:/* RAM bank 1 0x8000 - 0xBDFF */
239:RAM_nCS1 = PHI2 & Address:[8000..BEFF];
240:
241:
242:/* READ AND WRITE LINES */
243:RW = PHI2 & !RnW & !FT_CS ;
244:RD = PHI2 &  RnW & !FT_CS;
245:
246:
247:
248:/* system wide logic */
249:CLK_OUT = CLK;
250:LED = CLK;              /* Used for debugging */
251:
252:
253:
254:/* END OF FILE */
255:/*****************************************************/
