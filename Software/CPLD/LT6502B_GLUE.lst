119:
120:/*********************************************************
121: *                        PINNODES                       *
122: *********************************************************/
123:
124:/* Clock Stretch nodes */
125:Pinnode  0  = Q1;
126:Pinnode  0  = Q2;
127:
128:
129:/*********************************************************
130: *                   Local Variables                     *
131: *********************************************************/
132:FIELD Address = [A15..A0];
133:
134:
135:
136:
137:/*********************************************************
138: *                     Clock Bits and bobs               *
139: *********************************************************/
140:
141:
142:/* Clock Stretching */
143:Q0.ck = CLK;
144:Q1.ck = CLK;
145:Q2.ck = CLK;
146:PHI2.ck = CLK;
147:
148:Q0.ar = RESET;
149:Q1.ar = RESET;
150:Q2.ar = RESET;
151:PHI2.ar = RESET;
152:
153:Q0.D = !PHI2
154:       # PHI2 & !Q0;
155:
156:Q1.D = !PHI2 & !(DISP_nCS # FT_CS)
157:       # PHI2 & !Q1 & Q0
158:       # PHI2 & Q1 & !Q0;
159:
160:Q2.D = !PHI2 & !(ACIA_nCS # SID_nCS # MODEM_nCS)
161:       # PHI2 & Q2 & !Q1

LISTING FOR LOGIC DESCRIPTION FILE: LT6502B_GLUE.pld                 Page 4

CUPL(WM): Universal Compiler for Programmable Logic
Version 5.0a Serial# 60008009
Copyright (c) 1983, 1998 Logical Devices, Inc.
Created Sun Mar 22 09:43:33 2026

162:       # PHI2 & Q2 & !Q0        
163:       # PHI2 & !Q2 & Q1 & Q0;
164:
165:PHI2.D = !PHI2
166:       # PHI2 & !Q2     
167:       # PHI2 & !Q1
168:       # PHI2 & !Q0     
169:       # !PHI2 & Q2 & Q1 & Q0;
170:
171:
172:/*********************************************************
173: *                     Decode & glue                     *
174: *********************************************************/
175:
176:
177:/* FT245 Serial port 0xBFF0 - 0xBFFF */                 
178:FT_CS = PHI2 & Address:[BFF0..BFFF];
179:
180:RD_FT = PHI2 & FT_CS & A0 &  RnW;               /* 0xBFF1 */
181:WR_FT = PHI2 & FT_CS & A0 & !RnW;               /* 0xBFF1 */ 
182:D0.oe = FT_CS & !A0 & RnW;                      /* 0xBFF0 */
183:D1.oe = FT_CS & !A0 & RnW;                      /* 0xBFF0 */
184:
185:D0 = !RXF;                              
186:D1 = !TXE;                      
187:
188:
189:/* Keyboard ACIA - 0xBFE0 - 0xBFEF */
190:ACIA_nCS = PHI2 & Address:[BFE0..BFEF];
191: 
192:/* Display 0xBFD0 - 0xBFDF */
193:DISP_nCS = PHI2 & Address:[BFD0..BFDF];
194:DISP_DATA_EN = DISP_nCS & !A1;
195:DISP_E = DISP_nCS & PHI2 & !Q0 & !A1;
196:DISP_BL = 'b'1;                 /* toggling this causes board resets */
197:DISP_nRES = RESET;                      /* Not actually used */
198:D2 = DISP_nWT;
199:D2.OE = DISP_nCS & A1;
200:
201:/* Onboard VIA 65c22 0xBFC0 - 0xBFCF */
202:VIA_nCS = Address:[BFC0..BFCF];
203:
204:
205:/* Compact Flash 0xBFB0 - 0xBFBF */
206:CF_nCS = Address:[BFB0..BFBF];
207:CF_nRES = RESET;
208:
209:
210:/* Beeper, a simple SR latch for now - 0xBFA0 - 0xBFAF */
211:BEEP_CS = PHI2 & Address:[BFA0..BFAF];
212:
213:BEEP_S = D2 & BEEP_CS;
214:BEEP_R = !D2 & BEEP_CS;
215:BEEPER =  (BEEPER & !BEEP_R) # BEEP_S;

