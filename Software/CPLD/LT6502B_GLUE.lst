108:/* Data bus */
109:Pin 60 = D0;
110:Pin 58 = D1;
111:Pin 57 = D2;
112:Pin 56 = D3;
113:Pin 55 = D4;
114:Pin 54 = D5;
115:Pin 53 = D6;
116:Pin 52 = D7;
117:
